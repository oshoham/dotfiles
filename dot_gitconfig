[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[user]
	name = Oren Shoham
	email = oren.avraham.shoham@gmail.com
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[core]
	editor = vim
	symlinks = true
	filemode = true
	longpaths = true
[push]
	autoSetupRemote = true
[credential "helperselector"]
	selected = manager
[pull]
	ff = only
